          "type": "string",
          "description": "The database name for schema context. If not provided, uses the active connection."
        }
      },
      "required": [
        "name"
      ]
    }
  },
  {
    "name": "kusto_runQuery",
    "displayName": "Run KQL Query",
    "toolReferenceName": "kustoRunQuery",
    "canBeReferencedInPrompt": true,
    "userDescription": "Runs a KQL query and returns the results as markdown.",
    "tags": [
      "kusto",
      "kql",
      "query",
      "run",
      "execute",
      "results"
    ],
    "modelDescription": "Runs a KQL query in read-only mode and returns results as a markdown table. Use this when the user asks to execute a query or wants to see data from a Kusto database. When showResults is true, always append a KQL \u0027render\u0027 operator to the query (e.g. \u0027| render columnchart\u0027, \u0027| render piechart\u0027, \u0027| render timechart\u0027, \u0027| render barchart\u0027, \u0027| render linechart\u0027, etc.) choosing the most appropriate chart type for the data and the user\u0027s intent.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "The KQL query text to execute."
        },
        "cluster": {
          "type": "string",
          "description": "The Kusto cluster hostname. If not provided, uses the active connection."
        },
        "database": {
          "type": "string",
          "description": "The database name. If not provided, uses the active connection."
        },
        "maxRows": {
          "type": "number",
          "description": "Maximum number of rows to return. Use this to limit result size."
        },
        "showResults": {
          "type": "boolean",
          "description": "If true, displays the results in the results panel and chart panel. Defaults to false. When set to true, the query MUST include a \u0027render\u0027 operator (e.g. \u0027| render columnchart\u0027) to specify the chart visualization type."
        }
      },
      "required": [
        "query"
      ]
    }
  }
