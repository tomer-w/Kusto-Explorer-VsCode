{
  "name": "kusto-lsp",
  "displayName": "Kusto",
  "description": "Kusto Query Language (KQL)",
  "version": "0.1.0",
  "publisher": "Microsoft",
  "author": "Microsoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/Kusto-Language-Server"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [ "Programming Languages" ],
  "activationEvents": [ "onLanguage:kusto", "onLanguageModelTool:kusto_getDatabaseSchema", "onChatParticipant:kusto" ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "build-release-server": "dotnet publish ../KustoLspServer/KustoLspServer.csproj -c Release -o ./server",
    "build-debug-server": "dotnet publish ../KustoLspServer/KustoLspServer.csproj -c Debug -o ./server",
    "package": "copy ..\\..\\LICENSE . && npm run compile && npm run build-release-server && vsce package",
    "publish": "vsce publish"
  },
  "contributes": {
  "chatParticipants": [
    {
      "id": "kusto",
      "fullName": "Kusto",
      "name": "kusto",
      "description": "KQL expert assistant that helps write Kusto queries using your connected database schema",
      "isSticky": true
    }
  ],
  "languages": [
      {
        "id": "kusto",
        "extensions": [ ".kql", ".csl", ".kusto" ],
        "aliases": [ "Kql", "kql", "KQL", "Kusto", "kusto" ]
      }
    ],
    "grammars": [
      {
        "language": "kusto",
        "scopeName": "source.kusto",
        "path": "./syntaxes/kusto.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[kusto]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "commands": [
      {
        "command": "kusto.runQuery",
        "title": "Run Query",
        "icon": "$(play)"
      },
      {
        "command": "kusto.connectDatabase",
        "title": "Connect to Database",
        "icon": "$(database)"
      },
      {
        "command": "kusto.addServer",
        "title": "Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "kusto.addServerToGroup",
        "title": "Add Connection to Group",
        "icon": "$(add)"
      },
      {
        "command": "kusto.addServerGroup",
        "title": "Add Group",
        "icon": "$(new-folder)"
      },
      {
        "command": "kusto.removeServer",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "kusto.removeServerGroup",
        "title": "Remove Group",
        "icon": "$(trash)"
      },
      {
        "command": "kusto.moveServer",
        "title": "Move...",
        "icon": "$(move)"
      },
      {
        "command": "kusto.editServer",
        "title": "Edit...",
        "icon": "$(edit)"
      },
      {
        "command": "kusto.renameServer",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "kusto.renameServerGroup",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "kusto.copyQuery",
        "title": "Copy Query",
        "icon": "$(copy)"
      },
      {
        "command": "kusto.copyData",
        "title": "Copy Data",
        "icon": "$(copy)"
      },
      {
        "command": "kusto.formatQuery",
        "title": "Format Query"
      },
      {
        "command": "kusto.copyEntity",
        "title": "Copy Entity",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kusto.addServer",
          "when": "view == kusto.connections",
          "group": "navigation@1"
        },
        {
          "command": "kusto.addServerGroup",
          "when": "view == kusto.connections",
          "group": "navigation@2"
        },
        {
          "command": "kusto.copyData",
          "when": "view == kusto.resultsView",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "kusto.addServerToGroup",
          "when": "view == kusto.connections && viewItem == serverGroup",
          "group": "inline"
        },
        {
          "command": "kusto.removeServer",
          "when": "view == kusto.connections && viewItem == server",
          "group": "9_cutcopypaste"
        },
        {
          "command": "kusto.removeServerGroup",
          "when": "view == kusto.connections && viewItem == serverGroup",
          "group": "9_cutcopypaste"
        },
        {
          "command": "kusto.moveServer",
          "when": "view == kusto.connections && viewItem == server",
          "group": "7_modification"
        },
        {
          "command": "kusto.editServer",
          "when": "view == kusto.connections && viewItem == server",
          "group": "7_modification"
        },
        {
          "command": "kusto.renameServer",
          "when": "view == kusto.connections && viewItem == server",
          "group": "7_modification"
        },
        {
          "command": "kusto.renameServerGroup",
          "when": "view == kusto.connections && viewItem == serverGroup",
          "group": "7_modification"
        },
        {
          "command": "kusto.copyEntity",
          "when": "view == kusto.connections && viewItem =~ /^(table|materializedView|function|entityGroup|graphModel)$/",
          "group": "9_cutcopypaste"
        }
      ],
      "editor/title": [
        {
          "command": "kusto.runQuery",
          "when": "editorLangId == kusto",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "kusto.runQuery",
          "when": "editorLangId == kusto",
          "group": "navigation@1"
        },
        {
          "command": "kusto.copyQuery",
          "when": "editorLangId == kusto",
          "group": "9_cutcopypaste"
        },
        {
          "command": "kusto.connectDatabase",
          "when": "editorLangId == kusto",
          "group": "navigation@2"
        },
        {
          "command": "kusto.formatQuery",
          "when": "editorLangId == kusto",
          "group": "1_modification"
        }
      ],
      "webview/context": [
        {
          "command": "kusto.copyData",
          "when": "webviewId == 'kusto.resultsView'"
        }
      ]
    },
    "keybindings": [
      {
        "command": "kusto.runQuery",
        "key": "F5",
        "when": "editorLangId == kusto"
      },
      {
        "command": "kusto.connectDatabase",
        "key": "F6",
        "when": "editorLangId == kusto"
      },
      {
        "command": "editor.action.triggerSuggest",
        "key": "ctrl+space",
        "when": "editorLangId == kusto"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "kusto-panel",
          "title": "Results",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "kusto-panel": [
        {
          "type": "webview",
          "id": "kusto.resultsView",
          "name": "Results",
          "icon": "$(table)",
          "when": "kusto.hasActiveDocument"
        }
      ],
      "explorer": [
        {
          "id": "kusto.connections",
          "name": "Connections",
          "icon": "$(database)",
          "when": "kusto.hasActiveDocument"
        }
      ]
    },
    "configuration": [
      {
        "title": "Connections",
        "properties": {
          "kusto.connections": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "A list of Kusto cluster connections known by the editor."
          }
        }
      },
      {
        "title": "Editor",
        "properties": {
          "kusto.editor.showQuerySeparators": {
            "type": "boolean",
            "default": true,
            "description": "Show query separator lines (---) in the editor."
          }
        }
      },
      {
        "title": "Formatting",
        "properties": {
          "kusto.format.insertMissingTokens": {
            "type": "boolean",
            "default": false,
            "description": "Automatically add missing tokens (e.g., semicolons) when formatting"
          },
          "kusto.format.bracketStyle": {
            "type": "string",
            "enum": [ "none", "vertical", "diagonal" ],
            "default": "vertical",
            "description": "How brackets are styled when formatting"
          },
          "kusto.format.schemaBracketStyle": {
            "type": "string",
            "enum": [ "none", "vertical", "diagonal" ],
            "default": "vertical",
            "description": "How schema brackets are styled when formatting"
          },
          "kusto.format.dataTableBracketStyle": {
            "type": "string",
            "enum": [ "none", "vertical", "diagonal" ],
            "default": "vertical",
            "description": "How data table brackets are styled when formatting"
          },
          "kusto.format.functionBodyBracketStyle": {
            "type": "string",
            "enum": [ "none", "vertical", "diagonal" ],
            "default": "vertical",
            "description": "How function body braces are styled when formatting"
          },
          "kusto.format.functionParameterBracketStyle": {
            "type": "string",
            "enum": [ "none", "vertical", "diagonal" ],
            "default": "none",
            "description": "How parameter list parentheses are styled when formatting"
          },
          "kusto.format.functionArgumentBracketStyle": {
            "type": "string",
            "enum": [ "none", "vertical", "diagonal" ],
            "default": "none",
            "description": "How argument list parentheses are styled when formatting"
          },
          "kusto.format.pipeOperatorPlacementStyle": {
            "type": "string",
            "enum": [ "none", "newLine", "smart" ],
            "default": "smart",
            "description": "How query pipe operators (|) are placed when formatting"
          },
          "kusto.format.expressionListPlacementStyle": {
            "type": "string",
            "enum": [ "none", "newLine", "smart" ],
            "default": "smart",
            "description": "How expressions in a list are placed when formatting"
          },
          "kusto.format.statementListPlacementStyle": {
            "type": "string",
            "enum": [ "none", "newLine", "smart" ],
            "default": "smart",
            "description": "How statements in a list are placed when formatting"
          },
          "kusto.format.semicolonPlacementStyle": {
            "type": "string",
            "enum": [ "none", "newLine", "smart" ],
            "default": "none",
            "description": "How semicolons are placed when formatting"
          }
        }
      }
    ],
    "languageModelTools": [
      {
        "name": "kusto_getDatabaseSchema",
        "displayName": "Get Kusto Database Schema",
        "toolReferenceName": "kustoSchema",
        "canBeReferencedInPrompt": true,
        "userDescription": "Gets the schema of a Kusto (Azure Data Explorer) database including tables, columns, functions, materialized views, and external tables.",
        "tags": [ "kusto", "kql", "schema", "database", "adx", "azure data explorer", "tables", "columns" ],
        "modelDescription": "Retrieves the database schema for writing KQL queries. Returns table names, column names and types, functions, materialized views, and external tables. Call this when the user asks about Kusto/KQL queries or needs to know what data is available.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "cluster": {
              "type": "string",
              "description": "The Kusto cluster hostname. If not provided, uses the active document's connection."
            },
            "database": {
              "type": "string",
              "description": "The database name. If not provided, uses the active document's connection."
            }
          }
        }
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}