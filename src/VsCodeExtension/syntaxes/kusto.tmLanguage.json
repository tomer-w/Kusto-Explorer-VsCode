{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kusto",
  "scopeName": "source.kusto",
  "fileTypes": ["kql", "csl", "kusto"],
  "patterns": [
    {
      "name": "comment.line.double-slash.kusto",
      "match": "//.*"
    },
    {
      "name": "comment.line.number-sign.kusto",
      "match": "#.*"
    },
    {
      "name": "string.quoted.other.verbatim.kusto",
      "begin": "[hH]?@\"",
      "end": "\"(?!\")",
      "patterns": [
        {
          "name": "constant.character.escape.kusto",
          "match": "\"\""
        }
      ]
    },
    {
      "name": "string.quoted.other.verbatim.kusto",
      "begin": "[hH]?@'",
      "end": "'(?!')",
      "patterns": [
        {
          "name": "constant.character.escape.kusto",
          "match": "''"
        }
      ]
    },
    {
      "name": "string.quoted.double.kusto",
      "begin": "[hH]?\"",
      "end": "\"|$",
      "patterns": [
        {
          "name": "constant.character.escape.kusto",
          "match": "\\\\(?:[\\\\\"'nrtbafv0]|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8}|x[0-9a-fA-F]{2})"
        }
      ]
    },
    {
      "name": "string.quoted.single.kusto",
      "begin": "[hH]?'",
      "end": "'|$",
      "patterns": [
        {
          "name": "constant.character.escape.kusto",
          "match": "\\\\(?:[\\\\\"'nrtbafv0]|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8}|x[0-9a-fA-F]{2})"
        }
      ]
    },
    {
      "name": "string.quoted.multi.backtick.kusto",
      "begin": "[hH]?```",
      "end": "```"
    },
    {
      "name": "string.quoted.multi.tilde.kusto",
      "begin": "[hH]?~~~",
      "end": "~~~"
    },
    {
      "name": "keyword.control.kusto",
      "match": "\\b(where|summarize|extend|mvexpand|mv-expand|mv-apply|project-away|project-keep|project-rename|project-reorder|project|sort|join|union|limit|order|print|datatable|let|take|filter|distinct|count|render|search|find|parse|evaluate|invoke|fork|facet|make-series|partition|scan|lookup|getschema|serialize|range|sample|sample-distinct|top-nested|top-hitters|top|reduce|consume|materialize|external_data|externaldata)\\b"
    },
    {
      "name": "keyword.other.kusto",
      "match": "\\b(and|or|in|has|contains|startswith|endswith|matches|between|!in|!has|!contains|!startswith|!endswith|has_cs|contains_cs|startswith_cs|endswith_cs|!has_cs|!contains_cs|!startswith_cs|!endswith_cs|has_any|has_all)\\b"
    },
    {
      "name": "keyword.other.kusto",
      "match": "\\b(by|on|kind|with|as|of|asc|desc|nulls|first|last|default|inner|outer|left|right|anti|semi|fullouter|leftanti|leftsemi|rightanti|rightsemi|innerunique|table)\\b"
    },
    {
      "name": "keyword.other.kusto",
      "match": "\\b(writeaheadlog|workload_groups|workload_group|workload|whatsgoingon|whatif|warming|warm|w3clogfile|volatile|virtual_clusters|virtual_cluster|violations|views|viewers|version|verbose|v9|v10|utilization|using|users|user|usage|update|unused|until|unrestrictedviewers|undo|type|tsv|trim|transactions|traces|traceresults|trace|throw|threadpools|tenants|tempstorage|templates|template|tcpports|tcpconnections|tasks|task|tags|tables|table-purge|tablepurge|table_mirroring_templates|table_mirroring_template|systemdb|system_properties|suspend|streaming-ingestion-post-processing|streamingingestion_maintenance_mode|streamingingestion|stream|stored-query-results|storedqueryresultcontainers|stored_query_results|stored_query_result|storage-artifacts-cleanup|storage|status|stats|statistics|state|startofyear|startofweek|startofmonth|startofday|start|sstream|sql|softretention|softdelete|skip-seal|skip-results|shuffle|show|sharedcontainers|shards-group|shards_grouping|shards|sharding|shard-groups|set-or-replace|set-or-append|services|servicepoints|service|sensitive|secrets|seals|seal|script|schema|scalein|save|sandboxes|sandbox|running|runner|run|rowstores|rowstorepolicy|rowstore_sealinfo|rowstore_references|rowstore|roworderpolicy|roworder|row_level_security|roles|retention|resume-purges|resume|restricted_view_access|restore|resourcetree|resources|request_support|request_classification|rename|remote-schema|recycle|recoverability|records|record|rebuild|reason|readwrite|readonly|quote|queryplan|queryexecution|query-acceleration|query_weak_consistency|query_results|query_acceleration|query|queries|purge-storage-artifacts-cleanup|purge-cleanup|purge|principals-modification-kind|principals|principal|primary|pretty-name-override|prettyname|pretend|prefetch-extents|policy|policies|pod-name|plugins|plotly|persist|periodic-storage-artifacts-cleanup|period|pending|pathformat|patch|password|partitioning|parquet|pair_delimiter|over|orc|ops|operations|operation|onelake_client|older|node|network|nan|multidatabaseadmins|move|monitors|monitoring|missing|mirroring|migrated|method|metadata_artifacts|metadata|merge|mempools|memory|mdm|MB|maxRecords|materialized-views|materialized-view|mappings|mapping|management|managed_identity|make|maintenance_mode|lookback|location|local|load|leftovers|leader-key-vault-name|leader-cluster-metadata-path|latest|kv_delimiter|kuiper|kqlschema|kql|keyvaultsecrets|keyvault|keys|key|json|journal|jobs|job|internal|inline|ingestors|ingestiontime|ingestions|ingestionbatching|ingestion|ingest-inline|ingest-from-storage|ingest|info|include|immutable|ifnotexists|ifexists|if_later_than|identity|hours|hot_window|hash|hardretention|harddelete|groups|groupmembership|greedy|graph_snapshots_optimize|graph_snapshots_drop_by_retention|graph_snapshots|graph_snapshot|graph_models|graph_model|granularity|get|generic|GB|functions|function|freshness|format_datetime|for|follower|follow-authorized-principals|folder|flush|filesystem|featureflags|farm|failures|fabriclocks|fabricclocks|fabriccache|fabric|external-artifacts|external_throttling|external|extents-partition|extents-merge|extentsmerge|extentsize|extents|extentcontainers|extentcontainer|extent_tags_retention|extent|-exported-artifacts|exported-artifacts|export|expired_tables_cleanup|exclude|except|escape|ephemeral|entity_groups|entity|entities|encryption|encodingpolicy|encoding|enabled|enable|empty|effective|echo|earliest|dup-next-ingest|dup-next-failed-ingest|dryrun|drop-pretend|drop|docstring|dnshostname|disabled|disable|dimensions|diagnostics|details|detach|delete|define|default-principals-modification-kind|default-caching-policies-modification-kind|decryption-certificate-thumbprint|days|datetime_pattern|datastats|datasize|datamanagement|dataformat|data-export|dataexport|databases|database-name-prefix|database-name-override|databasecreators|data-analyzer|data_movement_restriction|data|cursor|csv|cslschema|csl|credstore|create-or-alter|create-merge|createdon|create|crash|corrupted|copy|continuous-job|continuous-exports|continuous-export|continuous|containers|container|conservative|configuration|concurrency|compute_pools|compute_pool|compressed|completed|complete|compact|commpools|commconcurrency|commands-and-queries|commands|command_line_args|columns|column-docstrings|column|cmk|clusters|clustermanagement|clusteradmin|cloudsettings|clear|cleanup|clean|classification|char|certificates|catalogquery|catalog|capacity|cancel|call-tree|callstacks|callouts|callout|cachingpolicy|caching-policies-modification-kind|caching|cache|bytes|byte|blockedprincipals|blocked|block|blob|based-on|azmonstream|avro|autoUpdateSchema|auto_delete|attach|async|assignments|assignment|artifacts|apply|application|append|apacheavro|alter-merge|alter|allow-non-empty-container|alldatabasesviewers|alldatabasesmonitors|alldatabasesadmins|admins|admin|adl|add|activitystate|accounts|account|abandoned|__unique|$systemdb-data)\\b"
    },
    {
      "name": "support.type.kusto",
      "match": "\\b(bool|boolean|date|datetime|decimal|double|dynamic|float|guid|int|int16|int32|int64|int8|long|real|string|time|timespan|uint|uint16|uint32|uint64|uint8|ulong|uniqueid)\\b"
    },
    {
      "name": "constant.language.kusto",
      "match": "\\b(true|false|null)\\b"
    },
    {
      "name": "constant.numeric.kusto",
      "match": "\\b(int|int32)\\s*\\([^)]*\\)"
    },
    {
      "name": "constant.numeric.kusto",
      "match": "\\b(long|int64)\\s*\\([^)]*\\)"
    },
    {
      "name": "constant.numeric.kusto",
      "match": "\\b(real|double)\\s*\\([^)]*\\)"
    },
    {
      "name": "constant.numeric.kusto",
      "match": "\\b(decimal)\\s*\\([^)]*\\)"
    },
    {
      "name": "constant.numeric.kusto",
      "match": "\\b0[xX][0-9a-fA-F]+\\b"
    },
    {
      "name": "constant.numeric.kusto",
      "match": "\\b[0-9]+(\\.[0-9]+)?([eE][\\+\\-]?[0-9]+)?\\b"
    },
    {
      "name": "constant.numeric.timespan.kusto",
      "match": "\\b[0-9]+(\\.[0-9]+)?(ms|microsecond|microseconds|millisecond|milliseconds|nanosecond|nanoseconds|tick|ticks|second|seconds|sec|minute|minutes|min|hour|hours|hr|hrs|day|days|[smhd])\\b"
    },
    {
      "name": "constant.numeric.timespan.kusto",
      "match": "\\b(time|timespan)\\s*\\([^)]*\\)"
    },
    {
      "name": "constant.numeric.datetime.kusto",
      "match": "\\b(datetime)\\s*\\([^)]*\\)"
    },
    {
      "name": "constant.other.guid.kusto",
      "match": "\\b(guid|uuid|uniqueid)\\s*\\([^)]*\\)"
    },
    {
      "name": "constant.language.typeof.kusto",
      "match": "\\b(typeof)\\s*\\([^)]*\\)"
    },
    {
      "name": "support.function.kusto",
      "match": "\\b(ago|now|datetime|timespan|time|guid|typeof|int|long|real|double|bool|decimal|dynamic|tostring|toint|tolong|todouble|toreal|todatetime|totimespan|tobool|toguid|todecimal|strlen|substring|toupper|tolower|trim|trim_start|trim_end|split|strcat|replace|extract|parse_json|parse_xml|parse_csv|parse_url|parse_path|parse_version|isempty|isnotempty|isnull|isnotnull|isnan|isinf|isfinite|coalesce|max_of|min_of|iff|iif|case|sum|avg|min|max|percentile|percentiles|stdev|variance|dcount|dcountif|countif|sumif|avgif|arg_max|arg_min|any|make_list|make_set|make_bag|make_list_if|make_set_if|make_bag_if|array_length|array_concat|array_slice|array_index_of|pack|pack_all|bag_keys|bag_pack|bag_merge|bag_remove_keys|set_union|set_intersect|set_difference|zip|repeat|toscalar|ingestion_time|format_datetime|format_timespan|bin|floor|ceiling|round|log|log10|log2|exp|exp10|exp2|pow|sqrt|abs|sign|sin|cos|tan|asin|acos|atan|atan2|degrees|radians|pi|hash|hash_sha256|hash_md5|base64_encode_tostring|base64_decode_tostring|url_encode|url_decode|gettype)\\b"
    },
    {
      "name": "variable.other.kusto",
      "match": "[0-9]*[_a-zA-Z][_a-zA-Z0-9]*"
    }
  ]
}