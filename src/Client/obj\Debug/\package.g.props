    ],
    "modelDescription": "Returns the result type of a KQL query. For tabular results, returns the table schema (column names and types). For scalar results, returns the scalar type. Returns null if the query does not produce a tabular or scalar result. Use this to understand what kind of data a query returns.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "The KQL query text to analyze."
