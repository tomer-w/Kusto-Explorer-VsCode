{
  "compilerOptions": {
    // File Layout
    "outDir": "./out",

    // Environment Settings
    "module": "commonjs",
    "target": "ES2020",
    "lib": [ "ES2020" ],
    "types": [ "node" ],

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "node"
  },
  "include": [ "**/*.ts" ],
  "exclude": [ "node_modules", "out", "tests" ]
}
