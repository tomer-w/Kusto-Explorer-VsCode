  {
    "name": "kusto_getFunctionResultType",
    "displayName": "Get Function Result Type",
    "toolReferenceName": "kustoFunctionResultType",
    "canBeReferencedInPrompt": true,
    "userDescription": "Gets the result type of a database function (table schema or scalar type).",
    "tags": [
      "kusto",
      "kql",
      "function",
      "result",
      "type",
      "schema"
    ],
    "modelDescription": "Returns the result type of a named database function. For functions that return tables, returns the table schema (column names and types). For scalar functions, returns the scalar type. Returns null if the function is not found. Note: the result may not include all possible columns if the function has a tabular parameter that contributes to the output.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the database function."
        },
        "cluster": {
          "type": "string",
          "description": "The Kusto cluster hostname for schema context. If not provided, uses the active connection."
        },
