{
  "compilerOptions": {
    "outDir": "./out",
    "rootDir": ".",
    "module": "nodenext",
    "target": "ES2020",
    "lib": [ "ES2020" ],
    "types": [ "node", "mocha" ],
    "sourceMap": true,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "nodenext"
  },
  "include": [ "tests/integration/**/*.ts" ]
}
